import "zx/globals";

import { writeFile } from "node:fs/promises";

import { Pool } from "pg";
import { makeIntrospectionQuery } from "pg-introspection";

const PORT = 9876;
const PASSWORD = "pgintrospection";
const CONTAINER_NAME = "pg-introspection-temp";

process.once(
  "exit",
  () => void $.sync({ nothrow: true })`docker rm -f -v ${CONTAINER_NAME}`,
);
const docker =
  await $`docker run --rm -d --name ${CONTAINER_NAME} -e POSTGRES_PASSWORD=${PASSWORD} -p ${PORT}:5432 postgres`;

const pool = new Pool({
  connectionString: `postgres://postgres:${PASSWORD}@127.0.0.1:${PORT}/postgres`,
});

// Wait for startup
const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));
let lastError: null | Error = null;
for (let attempts = 0; attempts < 100; attempts++) {
  try {
    await pool.query("select 1;");
    lastError = null;
    break;
  } catch (e) {
    lastError = e;
    await sleep(200);
  }
}
if (lastError) {
  console.log(docker.output?.text());
  throw lastError;
}

const sql = makeIntrospectionQuery();
const { rows } = await pool.query(sql);
const results = rows[0].introspection;
const RAW_RESULTS_FILE = `${import.meta.dirname}/../__tests__/rawIntrospectionResults.mts`;
await writeFile(
  RAW_RESULTS_FILE,
  `\
// This file is autogenerated; to regenerate:
// yarn update-raw-introspection-results
export const rawIntrospectionResults = JSON.parse(
  ${JSON.stringify(results)},
);
`,
);
await $`prettier --write ${RAW_RESULTS_FILE}`;
console.log("All done");
