%%{init: {'themeVariables': { 'fontSize': '12px'}}}%%
graph TD
    classDef path fill:#eee,stroke:#000,color:#000
    classDef plan fill:#fff,stroke-width:1px,color:#000
    classDef itemplan fill:#fff,stroke-width:2px,color:#000
    classDef unbatchedplan fill:#dff,stroke-width:1px,color:#000
    classDef sideeffectplan fill:#fcc,stroke-width:2px,color:#000
    classDef bucket fill:#f6f6f6,color:#000,stroke-width:2px,text-align:left

    subgraph "Buckets for subscriptions/v4/sub"
    Bucket0("Bucket 0 (root)<br /><br />1: <br />ᐳ: 6, 8, 21, 34, 10<br />2: Lambda[9]<br />3: Listen[11]"):::bucket
    Bucket1("Bucket 1 (subscription)<br />Deps: 2, 4, 21<br /><br />ROOT __Item{1}ᐸ11ᐳ[12]"):::bucket
    Bucket2("Bucket 2 (nullableBoundary)<br />Deps: 13, 2, 21<br /><br />ROOT JSONParse{1}ᐸ12ᐳ[13]<br />1: <br />ᐳ: Access[14]<br />2: Lambda[15]<br />ᐳ: Lambda[18], Lambda[19]"):::bucket
    Bucket3("Bucket 3 (polymorphic)<br />__typename: Lambda[19]<br />Deps: 19, 2, 18, 21"):::bucket
    Bucket4("Bucket 4 (polymorphicPartition)<br />|Query<br />Deps: 21<br />ᐳQuery"):::bucket
    Bucket5("Bucket 5 (polymorphicPartition)<br />|X<br />Deps: 2, 18<br />ᐳX<br /><br />1: Access[26], Access[27]<br />ᐳ: Access[33], Object[28]<br />2: PgSelect[25]<br />3: PgSelectRows[30]<br />ᐳ: 29, 31, 32"):::bucket
    end
    Bucket0 --> Bucket1
    Bucket1 --> Bucket2
    Bucket2 --> Bucket3
    Bucket3 --> Bucket4 & Bucket5

    %% plan dependencies
    Listen11[["Listen[11∈0@s] ➊"]]:::plan
    Access8{{"Access[8∈0] ➊<br />ᐸ2.pgSubscriberᐳ<br />More deps:<br />- __Value[2]"}}:::plan
    Lambda9[["Lambda[9∈0] ➊<br />More deps:<br />- Constantᐸ'x'ᐳ[34]"]]:::unbatchedplan
    Lambda10{{"Lambda[10∈0] ➊<br />ᐸinitialEventᐳ<br />More deps:<br />- Constantᐸundefinedᐳ[6]"}}:::plan
    Access8 & Lambda9 & Lambda10 --> Listen11
    __Value2["__Value[2∈0] ➊<br />ᐸcontextᐳ<br />Dependents: 3"]:::plan
    __Item12[/"__Item[12∈1]<br />ᐸ11ᐳ"\]:::itemplan
    Listen11 ==> __Item12
    JSONParse13[["JSONParse[13∈1]<br />ᐸ12ᐳ"]]:::plan
    __Item12 --> JSONParse13
    Access14{{"Access[14∈2]<br />ᐸ13.__node__ᐳ"}}:::plan
    JSONParse13 --> Access14
    Lambda15[["Lambda[15∈2]<br />ᐸnodeObjToNodeIdᐳ"]]:::unbatchedplan
    Access14 --> Lambda15
    Lambda18{{"Lambda[18∈2]<br />ᐸdecodeNodeIdWithCodecsᐳ"}}:::plan
    Lambda15 -->|rejectNull| Lambda18
    Lambda19{{"Lambda[19∈2]<br />ᐸfindTypeNameMatchᐳ"}}:::plan
    Lambda18 --> Lambda19
    PgSelect25[["PgSelect[25∈5]^<br />ᐸxᐳ"]]:::plan
    Object28{{"Object[28∈5] ➊^<br />ᐸ{pgSettings,withPgClient}ᐳ"}}:::plan
    Access33{{"Access[33∈5]<br />ᐸ18.base64JSON.1ᐳ<br />ᐳX"}}:::plan
    Access33 -->|rejectNull| PgSelect25
    Object28 --> PgSelect25
    Access26{{"Access[26∈5] ➊<br />ᐸ2.pgSettingsᐳ<br />ᐳX<br />More deps:<br />- __Value[2]"}}:::plan
    Access27{{"Access[27∈5] ➊<br />ᐸ2.withPgClientᐳ<br />ᐳX<br />More deps:<br />- __Value[2]"}}:::plan
    Access26 & Access27 --> Object28
    First29{{"First[29∈5]^"}}:::plan
    PgSelectRows30[["PgSelectRows[30∈5]^"]]:::plan
    PgSelectRows30 --> First29
    PgSelect25 --> PgSelectRows30
    PgSelectSingle31{{"PgSelectSingle[31∈5]^<br />ᐸxᐳ"}}:::plan
    First29 --> PgSelectSingle31
    PgClassExpression32{{"PgClassExpression[32∈5]^<br />ᐸ__x__.”name”ᐳ"}}:::plan
    PgSelectSingle31 --> PgClassExpression32
    Lambda18 --> Access33

    %% define steps
    classDef bucket0 stroke:#696969
    class Bucket0,__Value2,Access8,Lambda9,Lambda10,Listen11 bucket0
    classDef bucket1 stroke:#00bfff
    class Bucket1,__Item12,JSONParse13 bucket1
    classDef bucket2 stroke:#7f007f
    class Bucket2,Access14,Lambda15,Lambda18,Lambda19 bucket2
    classDef bucket3 stroke:#ffa500
    class Bucket3 bucket3
    classDef bucket4 stroke:#0000ff
    class Bucket4 bucket4
    classDef bucket5 stroke:#7fff00
    class Bucket5,PgSelect25,Access26,Access27,Object28,First29,PgSelectRows30,PgSelectSingle31,PgClassExpression32,Access33 bucket5

